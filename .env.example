# Personal Finance Agent — environment template.
# Copy to .env and fill in. The real .env is gitignored.

# Required for any tool that calls Claude (suggest_classification, the agent loop).
ANTHROPIC_API_KEY=

# Optional. Only set when running the LLM smoke tests that hit the API.
# Without this, agent/tools/classification.py's inline test skips suggest_classification.
RUN_LLM_TESTS=

# Optional. Enables the operator monitoring endpoint GET /admin/stats
# (web/backend/app.py). Unset → the endpoint returns 503 ("admin disabled").
# Set to a long random string in production, then query with:
#   curl -H "X-Admin-Token: <value>" https://financial-agent.michel-portfolio.co.uk/admin/stats
ADMIN_TOKEN=

# Optional. Root directory the Budget pipeline (classifier/budget_importer.py)
# reads raw bank exports from and writes its preprocessed CSV under. Layout:
#   $BUDGET_DATA_DIR/raw/<date>_amex.csv               (input)
#   $BUDGET_DATA_DIR/raw/<date>_accounts_download.csv  (input)
#   $BUDGET_DATA_DIR/raw/<date>_credit_card.csv        (input)
#   $BUDGET_DATA_DIR/raw/<date>_sainsbury.csv          (input)
#   $BUDGET_DATA_DIR/preprocessed/<date>_accounts_preprocessed.csv (output)
#   $BUDGET_DATA_DIR/budget.xlsx                       (dormant Excel-writer)
# Used by `python -m db.migrate --raw YYYY_MM_DD` (C1). Defaults to
# ./data/real, which is gitignored. Override per-invocation with
# `python -m db.migrate --raw ... --budget-root ./data/real_other`.
# BUDGET_DATA_DIR=./data/real
